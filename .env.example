# Copy to .env at the repo root: cp .env.example .env
# Shared by the frontend (VITE_*) and backend.

# --- Firebase project ---
FIREBASE_PROJECT_ID=your-firebase-project-id
# EXPECTED_FIREBASE_PROJECT_ID=your-firebase-project-id
# ALLOW_FIREBASE_PROJECT_MISMATCH=1

# --- Local emulators (recommended for development) ---
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# --- Cloud / production (comment out emulator lines above) ---
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# --- Backend ---
CORS_ORIGINS=http://localhost:5173
# MAX_UPLOAD_SIZE_BYTES=104857600
# AUTH_DISABLED=1

# --- Frontend ---
VITE_API_URL=/api
# Web app config: Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_USE_AUTH_EMULATOR=true
# VITE_USE_FIRESTORE_EMULATOR=true

# Auth emulator accepts any API key; use "demo-api-key" if VITE_USE_AUTH_EMULATOR=true.
# For production, set VITE_API_URL to your Cloud Run URL and VITE_USE_AUTH_EMULATOR=false.
