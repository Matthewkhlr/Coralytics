# Shared environment for frontend (VITE_*) and backend.
# Copy to .env at the repo root: cp .env.example .env

# Firebase project (replace with your Firebase project ID)
FIREBASE_PROJECT_ID=coralytics-dev

# Required for cloud Firestore (seed:cloud, production backend). Download from:
# Firebase Console → Project settings → Service accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Comma-separated frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# Frontend API base URL (use /api with Vite dev proxy, or http://localhost:8000 directly)
VITE_API_URL=/api

# Demo user for local development until Firebase Auth is wired up
VITE_DEMO_USER_ID=demo-user

# Max raw upload size accepted by the API (bytes). Default: 25 MB
# MAX_UPLOAD_SIZE_BYTES=26214400

# Use Firebase emulators locally (no service account needed)
FIRESTORE_EMULATOR_HOST=localhost:8080

# Allow POST /seed/sample-data against cloud Firestore (off by default; emulators always allow it)
# SEED_ENDPOINT_ENABLED=1
