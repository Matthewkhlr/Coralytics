# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
frontend/node_modules/
/.pnp
.pnp.js

# python
.venv/
venv/
backend/.venv/
__pycache__/
*.py[cod]

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log
firestore-debug.log
ui-debug.log

# local env files
.env*.local
.env

# firebase service account keys (never commit)
service-account*.json
*-firebase-adminsdk-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Coralytics ingestion output (contains real personal data - never commit)
backend/ingest_output/
backend/real_output/
backend/linkedin_output/
backend/combined_output/
backend/*_output/
ingest_output/
real_output/
*_output/

# Local Cloud Storage fallback used when Storage emulator is unset
backend/.local_object_store/
backend/app/.local_object_store/
backend/app/services/.local_object_store/