# Firebase project (replace with your Firebase project ID)
FIREBASE_PROJECT_ID=coralytics-dev

# Path to service-account JSON for local development against a real Firebase project.
# Not required when using Firebase emulators or when running on Cloud Run with ADC.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Comma-separated frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# Max raw upload size accepted by the API (bytes). Default: 25 MB
# MAX_UPLOAD_SIZE_BYTES=26214400

# Use Firebase emulators locally (no service account needed)
FIRESTORE_EMULATOR_HOST=localhost:8080
